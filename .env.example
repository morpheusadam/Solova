# PostgreSQL connection string (app database)
DATABASE_URL="postgresql://freelanceos:CHANGE_ME@127.0.0.1:5433/freelanceos"
# Separate database used only by the automated test suite
TEST_DATABASE_URL="postgresql://freelanceos:CHANGE_ME@127.0.0.1:5433/freelanceos_test"
# Auth.js session encryption secret — generate with: openssl rand -base64 33
AUTH_SECRET="CHANGE_ME"
# Public origin of the app (used for auth callbacks)
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
# Directory where card attachments and logos are stored
UPLOADS_DIR="./data/uploads"
